<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
<title>SIGNAL — Read Between The Lines</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;800&display=swap" rel="stylesheet" />
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
:root {
  --bg:#06060f;--card:#10101e;--border:#1c1c30;--accent:#ff2d55;--violet:#8b5cf6;--cyan:#22d3ee;--gold:#fbbf24;--green:#10b981;--text:#f0efff;--muted:#5a5a7a;--dim:#2a2a45;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 60% 40% at 15% 10%,rgba(255,45,85,0.06) 0%,transparent 70%),radial-gradient(ellipse 50% 50% at 85% 90%,rgba(139,92,246,0.06) 0%,transparent 70%);pointer-events:none;z-index:0;}
#root{position:relative;z-index:1;}
.app{max-width:680px;margin:0 auto;padding:0 16px 80px;}
.header{text-align:center;padding:48px 0 36px;}
.logo{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,18vw,108px);letter-spacing:12px;line-height:1;background:linear-gradient(160deg,#ff2d55 0%,#8b5cf6 55%,#22d3ee 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 40px rgba(255,45,85,0.25));}
.logo-sub{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:5px;color:var(--muted);text-transform:uppercase;margin-top:6px;}
.setup-card{background:var(--card);border:1px solid rgba(255,45,85,0.3);border-radius:18px;padding:24px;margin-bottom:20px;}
.setup-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:3px;color:var(--accent);margin-bottom:8px;}
.setup-desc{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);line-height:1.7;margin-bottom:14px;}
.setup-desc a{color:var(--cyan);text-decoration:none;}
.setup-input-row{display:flex;gap:8px;}
.setup-input{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:12px;outline:none;transition:border-color 0.2s;}
.setup-input:focus{border-color:var(--accent);}
.setup-input::placeholder{color:var(--muted);}
.setup-save-btn{padding:12px 20px;background:linear-gradient(135deg,var(--accent),var(--violet));border:none;border-radius:10px;color:white;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1px;cursor:pointer;white-space:nowrap;}
.setup-note{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);margin-top:10px;line-height:1.6;}
.key-saved{display:flex;align-items:center;justify-content:space-between;background:rgba(16,185,129,0.07);border:1px solid rgba(16,185,129,0.2);border-radius:10px;padding:10px 14px;margin-top:10px;}
.key-saved-text{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--green);}
.key-clear-btn{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);background:none;border:none;cursor:pointer;}
.key-clear-btn:hover{color:var(--accent);}
.usage-row{display:flex;align-items:center;justify-content:space-between;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:12px 18px;margin-bottom:20px;}
.usage-left{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);}
.usage-left span{color:var(--accent);font-weight:700;}
.usage-dots{display:flex;gap:8px;}
.dot{width:11px;height:11px;border-radius:50%;border:1.5px solid var(--dim);background:transparent;transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1);}
.dot.used{background:var(--accent);border-color:var(--accent);box-shadow:0 0 10px rgba(255,45,85,0.7);}
.usage-reset{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);}
.scan-toggle{display:flex;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:5px;gap:5px;margin-bottom:18px;}
.scan-opt{flex:1;padding:12px 8px;border:none;border-radius:10px;background:transparent;cursor:pointer;transition:all 0.25s;text-align:center;}
.scan-opt-title{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:2px;color:var(--muted);display:block;}
.scan-opt-desc{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--dim);display:block;margin-top:2px;}
.scan-opt.active{background:linear-gradient(135deg,rgba(255,45,85,0.15),rgba(139,92,246,0.15));border:1px solid rgba(255,45,85,0.3);}
.scan-opt.active .scan-opt-title{color:var(--text);}
.scan-opt.active .scan-opt-desc{color:var(--muted);}
.input-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:20px;margin-bottom:14px;transition:border-color 0.3s;}
.input-card:focus-within{border-color:rgba(255,45,85,0.35);}
.input-label{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;display:block;margin-bottom:12px;}
.chat-input{width:100%;background:transparent;border:none;outline:none;color:var(--text);font-family:'Syne',sans-serif;font-size:14px;line-height:1.7;resize:none;min-height:150px;}
.chat-input::placeholder{color:var(--muted);font-style:italic;}
.input-footer{display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:12px;border-top:1px solid var(--border);}
.char-count{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);}
.clear-btn{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);background:none;border:none;cursor:pointer;letter-spacing:1px;text-transform:uppercase;}
.clear-btn:hover{color:var(--accent);}
.analyze-btn{width:100%;padding:20px;border:none;border-radius:16px;background:linear-gradient(135deg,#ff2d55 0%,#8b5cf6 100%);color:white;font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:5px;cursor:pointer;transition:all 0.25s;box-shadow:0 4px 30px rgba(255,45,85,0.35);}
.analyze-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 10px 50px rgba(255,45,85,0.5);}
.analyze-btn:disabled{opacity:0.4;cursor:not-allowed;transform:none;box-shadow:none;}
.loading-wrap{padding:48px 0;text-align:center;}
.loading-label{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--accent);text-transform:uppercase;animation:flicker 1.8s ease-in-out infinite;}
@keyframes flicker{0%,100%{opacity:1}50%{opacity:0.2}}
.loading-track{width:100%;height:2px;background:var(--border);border-radius:2px;margin-top:20px;overflow:hidden;}
.loading-fill{height:100%;width:35%;background:linear-gradient(90deg,var(--accent),var(--violet));border-radius:2px;animation:sweep 1.6s ease-in-out infinite;}
@keyframes sweep{0%{transform:translateX(-200%)}100%{transform:translateX(500%)}}
.results{animation:riseUp 0.5s cubic-bezier(0.22,1,0.36,1) forwards;}
@keyframes riseUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.section-label{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:5px;color:var(--muted);text-transform:uppercase;text-align:center;margin:32px 0 18px;}
.redflag-card{background:var(--card);border:1px solid rgba(255,45,85,0.2);border-radius:20px;padding:32px 24px;text-align:center;margin-bottom:14px;position:relative;overflow:hidden;}
.redflag-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
.redflag-card::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(255,45,85,0.05) 0%,transparent 70%);pointer-events:none;}
.rf-label{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:4px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;}
.rf-number{font-family:'Bebas Neue',sans-serif;font-size:110px;line-height:1;background:linear-gradient(160deg,#ff2d55,#ff6b35);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 30px rgba(255,45,85,0.5));}
.rf-pct{font-size:48px;}
.rf-verdict{font-size:13px;font-weight:600;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-top:4px;}
.cares-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px;margin-bottom:14px;}
.cares-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:16px;text-align:center;}
.cares-bar-wrap{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.cares-side{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);width:34px;text-align:center;flex-shrink:0;}
.cares-track{flex:1;height:10px;background:var(--dim);border-radius:99px;overflow:hidden;display:flex;}
.cares-fill-left{height:100%;background:linear-gradient(90deg,var(--accent),#ff6b35);transition:width 1s cubic-bezier(0.22,1,0.36,1);border-radius:99px 0 0 99px;}
.cares-fill-right{height:100%;background:linear-gradient(90deg,var(--violet),var(--cyan));transition:width 1s cubic-bezier(0.22,1,0.36,1);border-radius:0 99px 99px 0;}
.cares-result{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:3px;text-align:center;color:var(--text);margin-top:8px;}
.score-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.score-cell{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px 16px;position:relative;overflow:hidden;}
.score-cell::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 16px 16px;}
.score-cell[data-color="red"]::after{background:var(--accent);}
.score-cell[data-color="violet"]::after{background:var(--violet);}
.score-cell[data-color="cyan"]::after{background:var(--cyan);}
.score-cell[data-color="gold"]::after{background:var(--gold);}
.score-cell[data-color="green"]::after{background:var(--green);}
.score-name{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;display:block;margin-bottom:10px;}
.score-val{font-family:'Bebas Neue',sans-serif;font-size:46px;line-height:1;display:block;}
.score-cell[data-color="red"] .score-val{color:var(--accent);}
.score-cell[data-color="violet"] .score-val{color:var(--violet);}
.score-cell[data-color="cyan"] .score-val{color:var(--cyan);}
.score-cell[data-color="gold"] .score-val{color:var(--gold);}
.score-cell[data-color="green"] .score-val{color:var(--green);}
.score-bar-track{width:100%;height:3px;background:var(--dim);border-radius:99px;margin-top:10px;overflow:hidden;}
.score-bar-fill{height:100%;border-radius:99px;transition:width 1.2s cubic-bezier(0.22,1,0.36,1);}
.score-cell[data-color="red"] .score-bar-fill{background:var(--accent);}
.score-cell[data-color="violet"] .score-bar-fill{background:var(--violet);}
.score-cell[data-color="cyan"] .score-bar-fill{background:var(--cyan);}
.score-cell[data-color="gold"] .score-bar-fill{background:var(--gold);}
.score-cell[data-color="green"] .score-bar-fill{background:var(--green);}
.translation-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px;margin-bottom:14px;}
.translation-header{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:16px;}
.translation-item{border-bottom:1px solid var(--border);padding:14px 0;}
.translation-item:last-child{border-bottom:none;}
.t-original{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--muted);font-style:italic;margin-bottom:8px;line-height:1.5;}
.t-arrow{font-size:10px;color:var(--accent);margin-bottom:6px;display:block;}
.t-real{font-size:14px;font-weight:600;color:var(--text);line-height:1.5;}
.reply-card{background:var(--card);border:1px solid rgba(34,211,238,0.2);border-radius:20px;padding:24px;margin-bottom:14px;position:relative;overflow:hidden;}
.reply-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);}
.reply-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:12px;}
.reply-pct{font-family:'Bebas Neue',sans-serif;font-size:64px;color:var(--cyan);line-height:1;filter:drop-shadow(0 0 15px rgba(34,211,238,0.4));}
.reply-pct-unit{font-size:28px;}
.reply-desc{font-size:13px;color:var(--muted);margin-top:6px;line-height:1.5;}
.reply-suggested{margin-top:14px;padding:14px;background:rgba(34,211,238,0.06);border:1px solid rgba(34,211,238,0.15);border-radius:12px;font-size:13px;color:var(--text);font-style:italic;line-height:1.6;}
.reply-suggested-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;display:block;margin-bottom:6px;}
.summary-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px;margin-bottom:14px;}
.summary-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:14px;}
.summary-text{font-size:15px;line-height:1.8;color:var(--text);}
.attach-card{background:var(--card);border:1px solid rgba(251,191,36,0.2);border-radius:20px;padding:24px;margin-bottom:14px;}
.attach-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:12px;}
.attach-style{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:2px;color:var(--gold);display:block;margin-bottom:8px;}
.attach-desc{font-size:13px;color:var(--muted);line-height:1.6;}
.share-btn{width:100%;padding:16px;border:1.5px solid var(--border);border-radius:14px;background:transparent;color:var(--muted);font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;margin-bottom:10px;}
.share-btn:hover{border-color:var(--accent);color:var(--accent);}
.limit-notice{background:rgba(255,45,85,0.07);border:1px solid rgba(255,45,85,0.2);border-radius:14px;padding:20px;text-align:center;margin-top:16px;}
.limit-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:3px;color:var(--accent);display:block;margin-bottom:6px;}
.limit-text{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);line-height:1.6;}
.donate-banner{background:linear-gradient(135deg,rgba(139,92,246,0.1),rgba(255,45,85,0.1));border:1px solid rgba(139,92,246,0.2);border-radius:16px;padding:20px;text-align:center;margin-top:24px;}
.donate-text{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);margin-bottom:12px;line-height:1.6;}
.donate-btn{display:inline-block;padding:10px 24px;background:linear-gradient(135deg,var(--violet),var(--accent));border:none;border-radius:99px;color:white;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:2px;cursor:pointer;text-decoration:none;}
.error-box{background:rgba(255,45,85,0.08);border:1px solid rgba(255,45,85,0.3);border-radius:14px;padding:16px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent);text-align:center;margin-top:12px;}
.footer{text-align:center;padding-top:40px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:2px;}
.footer a{color:var(--violet);text-decoration:none;}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const CONFIG = {
  API_URL:"https://openrouter.ai/api/v1/chat/completions",
  MODEL:"anthropic/claude-3-haiku",
  DAILY_LIMIT:3,
  KEY_STORAGE:"signal_api_key",
  USAGE_KEY:"signal_usage",
  DONATE_URL:"https://buymeacoffee.com/YOUR_USERNAME",
  GITHUB_URL:"https://github.com/YOUR_USERNAME/signal-app",
};

function todayStr(){return new Date().toISOString().split("T")[0];}
function getApiKey(){return localStorage.getItem(CONFIG.KEY_STORAGE)||"";}
function saveApiKey(k){localStorage.setItem(CONFIG.KEY_STORAGE,k.trim());}
function clearApiKey(){localStorage.removeItem(CONFIG.KEY_STORAGE);}
function getUsage(){try{const r=localStorage.getItem(CONFIG.USAGE_KEY);if(!r)return{count:0,date:todayStr()};return JSON.parse(r);}catch{return{count:0,date:todayStr()};}}
function saveUsage(d){localStorage.setItem(CONFIG.USAGE_KEY,JSON.stringify(d));}
function getRemainingScans(){let u=getUsage();if(u.date!==todayStr()){u={count:0,date:todayStr()};saveUsage(u);}return CONFIG.DAILY_LIMIT-u.count;}
function incrementUsage(){let u=getUsage();if(u.date!==todayStr())u={count:0,date:todayStr()};u.count+=1;saveUsage(u);}

function buildPrompt(text,mode){
  const depth=mode==="deep"?"Perform a DEEP psychological analysis. Be extremely detailed, blunt, and clinical.":"Perform a QUICK analysis. Be concise, sharp, and punchy.";
  return `${depth}\n\nAnalyze the following chat and return JSON ONLY — no markdown, no preamble.\n\nMessages:\n---\n${text}\n---\n\nReturn this exact JSON:\n{\n  "redFlagPercent":<0-100>,\n  "redFlagVerdict":"<dramatic phrase>",\n  "whoCaresMore":{"person1Label":"<THEM>","person2Label":"<YOU>","person1Percent":<0-100>,"person2Percent":<0-100>,"winner":"<blunt statement>"},\n  "scores":{"honestyLevel":<0-100>,"manipulationLevel":<0-100>,"emotionalTone":<0-100>,"interestLevel":<0-100>,"ghostingRisk":<0-100>,"emotionalControl":<0-100>},\n  "attachmentStyle":{"style":"<Anxious/Avoidant/Secure/Fearful-Avoidant>","description":"<2 blunt sentences>"},\n  "translations":[{"original":"<quote>","realMeaning":"<blunt>"},{"original":"<quote>","realMeaning":"<blunt>"},{"original":"<quote>","realMeaning":"<blunt>"}],\n  "replyProbability":<0-100>,\n  "replyAnalysis":"<1-2 sentences>",\n  "suggestedReply":"<power move or No reply recommended>",\n  "summary":"<3-4 sentence brutal honest summary>"\n}`;
}

const {useState,useRef}=React;

function App(){
  const [apiKey,setApiKey]=useState(getApiKey());
  const [keyInput,setKeyInput]=useState("");
  const [text,setText]=useState("");
  const [mode,setMode]=useState("quick");
  const [loading,setLoading]=useState(false);
  const [result,setResult]=useState(null);
  const [error,setError]=useState("");
  const [scansLeft,setScansLeft]=useState(getRemainingScans());
  const resultsRef=useRef(null);
  const usedScans=CONFIG.DAILY_LIMIT-scansLeft;
  const midnight=new Date();midnight.setHours(24,0,0,0);
  const hoursLeft=Math.ceil((midnight-new Date())/3600000);

  function handleSaveKey(){if(!keyInput.trim())return;saveApiKey(keyInput);setApiKey(keyInput.trim());setKeyInput("");}
  function handleClearKey(){clearApiKey();setApiKey("");setResult(null);setError("");}

  async function analyze(){
    if(!apiKey){setError("Enter your OpenRouter API key first.");return;}
    if(!text.trim()){setError("Paste some messages first.");return;}
    if(scansLeft<=0){setError("Daily limit reached. Come back tomorrow.");return;}
    setError("");setResult(null);setLoading(true);
    try{
      const res=await fetch(CONFIG.API_URL,{
        method:"POST",
        headers:{"Content-Type":"application/json","Authorization":`Bearer ${apiKey}`,"HTTP-Referer":"https://signal-app.github.io","X-Title":"Signal App"},
        body:JSON.stringify({model:CONFIG.MODEL,max_tokens:mode==="deep"?2000:1200,messages:[{role:"user",content:buildPrompt(text,mode)}]}),
      });
      if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e?.error?.message||`API error ${res.status}`);}
      const data=await res.json();
      const raw=data.choices?.[0]?.message?.content||"";
      const cleaned=raw.replace(/```json|```/g,"").trim();
      const parsed=JSON.parse(cleaned);
      incrementUsage();setScansLeft(getRemainingScans());setResult(parsed);
      setTimeout(()=>resultsRef.current?.scrollIntoView({behavior:"smooth"}),100);
    }catch(e){
      setError(e.message.includes("JSON")?"Couldn't parse the analysis. Try again.":e.message.includes("401")?"Invalid API key. Check and re-enter it.":e.message||"Something went wrong.");
    }finally{setLoading(false);}
  }

  function copyResults(){
    if(!result)return;
    const txt=`🚩 RED FLAG SCORE: ${result.redFlagPercent}%\n💔 WHO CARES MORE: ${result.whoCaresMore?.winner}\n🔍 HONESTY: ${result.scores?.honestyLevel}/100\n🎭 MANIPULATION: ${result.scores?.manipulationLevel}/100\n👻 GHOSTING RISK: ${result.scores?.ghostingRisk}/100\n📱 REPLY PROBABILITY: ${result.replyProbability}%\n\n📊 Analyzed by SIGNAL`;
    navigator.clipboard.writeText(txt).catch(()=>{});
    alert("Copied! Perfect for sharing 📱");
  }

  return(
    <div className="app">
      <header className="header">
        <div className="logo">SIGNAL</div>
        <div className="logo-sub">Read Between The Lines</div>
      </header>

      <div className="setup-card">
        <div className="setup-title">API Key Setup</div>
        <div className="setup-desc">Get a free key at <a href="https://openrouter.ai/keys" target="_blank" rel="noopener">openrouter.ai/keys</a> — stays on your device only.</div>
        {!apiKey?(
          <>
            <div className="setup-input-row">
              <input className="setup-input" type="password" placeholder="sk-or-v1-..." value={keyInput} onChange={e=>setKeyInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&handleSaveKey()}/>
              <button className="setup-save-btn" onClick={handleSaveKey}>Save</button>
            </div>
            <div className="setup-note">🔒 Saved locally. Never shared.</div>
          </>
        ):(
          <div className="key-saved">
            <span className="key-saved-text">✓ API key saved</span>
            <button className="key-clear-btn" onClick={handleClearKey}>Change key</button>
          </div>
        )}
      </div>

      <div className="usage-row">
        <div className="usage-left">Daily scans: <span>{scansLeft}</span> left</div>
        <div className="usage-dots">{[...Array(CONFIG.DAILY_LIMIT)].map((_,i)=><div key={i} className={`dot ${i<usedScans?"used":""}`}/>)}</div>
        <div className="usage-reset">Resets in {hoursLeft}h</div>
      </div>

      <div className="scan-toggle">
        <button className={`scan-opt ${mode==="quick"?"active":""}`} onClick={()=>setMode("quick")}>
          <span className="scan-opt-title">Quick Scan</span>
          <span className="scan-opt-desc">Fast • Punchy • Sharp</span>
        </button>
        <button className={`scan-opt ${mode==="deep"?"active":""}`} onClick={()=>setMode("deep")}>
          <span className="scan-opt-title">Deep Scan</span>
          <span className="scan-opt-desc">Detailed • Clinical • Full</span>
        </button>
      </div>

      <div className="input-card">
        <label className="input-label">Paste your messages</label>
        <textarea className="chat-input" placeholder={'Paste any chat here — texts, DMs, arguments, dating convos...\n\nExample:\nThem: "yeah sure whatever"\nYou: "are you mad at me?"\nThem: "I\'m fine"'} value={text} onChange={e=>setText(e.target.value)} maxLength={mode==="quick"?2000:5000}/>
        <div className="input-footer">
          <span className="char-count">{text.length} / {mode==="quick"?"2000":"5000"}</span>
          <button className="clear-btn" onClick={()=>{setText("");setResult(null);setError("");}}>Clear</button>
        </div>
      </div>

      <button className="analyze-btn" onClick={analyze} disabled={loading||scansLeft<=0||!text.trim()||!apiKey}>
        {loading?"READING...":`ANALYZE — ${mode.toUpperCase()} SCAN`}
      </button>

      {error&&<div className="error-box">⚠ {error}</div>}

      {loading&&(
        <div className="loading-wrap">
          <div className="loading-label">{mode==="deep"?"Running deep psychological scan...":"Decoding subtext..."}</div>
          <div className="loading-track"><div className="loading-fill"/></div>
        </div>
      )}

      {result&&(
        <div className="results" ref={resultsRef}>
          <div className="section-label">Analysis Complete</div>
          <div className="redflag-card">
            <div className="rf-label">🚩 Red Flag Meter</div>
            <div className="rf-number">{result.redFlagPercent}<span className="rf-pct">%</span></div>
            <div className="rf-verdict">{result.redFlagVerdict}</div>
          </div>
          {result.whoCaresMore&&(
            <div className="cares-card">
              <div className="cares-title">💔 Who Cares More</div>
              <div className="cares-bar-wrap">
                <span className="cares-side">{result.whoCaresMore.person1Label}</span>
                <div className="cares-track">
                  <div className="cares-fill-left" style={{width:`${result.whoCaresMore.person1Percent}%`}}/>
                  <div className="cares-fill-right" style={{width:`${result.whoCaresMore.person2Percent}%`}}/>
                </div>
                <span className="cares-side">{result.whoCaresMore.person2Label}</span>
              </div>
              <div className="cares-result">{result.whoCaresMore.winner}</div>
            </div>
          )}
          {result.scores&&(
            <>
              <div className="section-label">Psychological Scores</div>
              <div className="score-grid">
                <ScoreCell label="Honesty" value={result.scores.honestyLevel} color="green"/>
                <ScoreCell label="Manipulation" value={result.scores.manipulationLevel} color="red"/>
                <ScoreCell label="Emotional Tone" value={result.scores.emotionalTone} color="violet"/>
                <ScoreCell label="Interest Level" value={result.scores.interestLevel} color="cyan"/>
                <ScoreCell label="Ghosting Risk" value={result.scores.ghostingRisk} color="red"/>
                <ScoreCell label="Emotional Control" value={result.scores.emotionalControl} color="gold"/>
              </div>
            </>
          )}
          {result.attachmentStyle&&(
            <div className="attach-card">
              <div className="attach-title">🧠 Attachment Style Detected</div>
              <span className="attach-style">{result.attachmentStyle.style}</span>
              <div className="attach-desc">{result.attachmentStyle.description}</div>
            </div>
          )}
          {result.translations?.length>0&&(
            <>
              <div className="section-label">What They Really Mean</div>
              <div className="translation-card">
                <div className="translation-header">Real Translation</div>
                {result.translations.map((t,i)=>(
                  <div className="translation-item" key={i}>
                    <div className="t-original">"{t.original}"</div>
                    <span className="t-arrow">▼ ACTUALLY MEANS</span>
                    <div className="t-real">{t.realMeaning}</div>
                  </div>
                ))}
              </div>
            </>
          )}
          <div className="reply-card">
            <div className="reply-title">📱 Reply Probability</div>
            <div className="reply-pct">{result.replyProbability}<span className="reply-pct-unit">%</span></div>
            <div className="reply-desc">{result.replyAnalysis}</div>
            {result.suggestedReply&&result.suggestedReply!=="No reply recommended"&&(
              <div className="reply-suggested">
                <span className="reply-suggested-label">Suggested Reply</span>
                {result.suggestedReply}
              </div>
            )}
          </div>
          <div className="summary-card">
            <div className="summary-title">🔍 Psychological Summary</div>
            <div className="summary-text">{result.summary}</div>
          </div>
          <button className="share-btn" onClick={copyResults}>📋 Copy Results for TikTok / Story</button>
          {scansLeft===0&&(
            <div className="limit-notice">
              <span className="limit-title">Daily Limit Reached</span>
              <div className="limit-text">All 3 scans used. Resets in {hoursLeft}h.</div>
            </div>
          )}
          <div className="donate-banner">
            <div className="donate-text">Signal is free & open source.<br/>Support development ☕</div>
            <a className="donate-btn" href={CONFIG.DONATE_URL} target="_blank" rel="noopener">Support Signal</a>
          </div>
        </div>
      )}
      <div className="footer">
        <a href={CONFIG.GITHUB_URL} target="_blank" rel="noopener">GitHub</a> · Open Source · Signal App
      </div>
    </div>
  );
}

function ScoreCell({label,value,color}){
  return(
    <div className="score-cell" data-color={color}>
      <span className="score-name">{label}</span>
      <span className="score-val">{value}</span>
      <div className="score-bar-track"><div className="score-bar-fill" style={{width:`${value}%`}}/></div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>